

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-chat-left-text"></i> Написать сообщение
                    </h4>
                </div>

                <div class="card-body">
                    <div class="mb-4">
                        <h5>Получатель:</h5>
                        <div class="alert alert-info">
                            <strong>@Model.FirstName </strong> (@Model.Email)
                        </div>
                    </div>
                    <form method="post" action="@Url.Action("SendMessege", "Messege")">
                        <input type="hidden" name="Email" value="@Model.Email" />
                        <p></p>
                        <div class="mb-3">
                            <label class="form-label">Сообщение</label>
                            <textarea name="messegeText"
                                      class="form-control"
                                      rows="6"
                                      placeholder="Введите текст сообщения..."
                                      required></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("FriendsView", "Friends")"
                               class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Назад к друзьям
                            </a>

                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-send"></i> Отправить сообщение
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    textarea {
        resize: vertical;
        min-height: 150px;
    }

    .alert-info {
        background-color: #d1ecf1;
        border-color: #bee5eb;
        color: #0c5460;
    }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">