@model Social_network.DAL.Models.User
@{
    ViewData["Title"] = "Профиль";
}

<style>
    .profile-container {
        max-width: 800px;
        margin: 40px auto;
        padding: 30px;
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        border-radius: 20px;
        color: white;
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        position: relative;
        overflow: hidden;
    }

        .profile-container::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #00c6ff, #0072ff);
        }

    .profile-header {
        text-align: center;
        margin-bottom: 40px;
        position: relative;
    }

    .welcome-text {
        font-size: 2.5rem;
        font-weight: 300;
        margin-bottom: 10px;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
    }

    .user-name {
        font-size: 1.8rem;
        font-weight: 600;
        color: #fff;
        background: rgba(255,255,255,0.1);
        display: inline-block;
        padding: 10px 30px;
        border-radius: 50px;
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.2);
    }

    .profile-card {
        background: rgba(255, 255, 255, 0.95);
        border-radius: 15px;
        padding: 30px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
        margin-bottom: 30px;
        color: #333;
    }

    .profile-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
    }

    .info-item {
        margin-bottom: 15px;
    }

    .info-label {
        display: block;
        font-size: 0.9rem;
        color: #666;
        margin-bottom: 5px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .info-value {
        font-size: 1.2rem;
        font-weight: 500;
        color: #333;
        padding: 8px 0;
        border-bottom: 2px solid #f0f0f0;
    }

    .buttons-container {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        justify-content: center;
        margin-top: 30px;
    }

    .profile-btn {
        padding: 15px 30px;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.3s ease;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        min-width: 200px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
    }

        .profile-btn:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
        }

    .btn-friends {
        background: linear-gradient(45deg, #4776E6, #8E54E9);
        color: white;
    }

    .btn-messages {
        background: linear-gradient(45deg, #00b09b, #96c93d);
        color: white;
    }

    .btn-edit {
        background: linear-gradient(45deg, #FF416C, #FF4B2B);
        color: white;
    }

    .icon {
        font-size: 1.2rem;
    }

    .birthday-icon {
        color: #e74c3c;
    }

    .email-icon {
        color: #3498db;
    }

    .name-icon {
        color: #9b59b6;
    }
</style>

<div class="profile-container">
    <div class="profile-header">
        <h1 class="welcome-text">Добро пожаловать</h1>
        <div class="user-name">@Model.FirstName @Model.LastName</div>
    </div>

    <div class="profile-card">
        <h2 style="text-align: center; margin-bottom: 25px; color: #333; font-weight: 600;">
            <i class="icon">👤</i> Информация профиля
        </h2>

        <div class="profile-info">
            <div class="info-item">
                <span class="info-label"><i class="icon name-icon">👤</i> Имя</span>
                <div class="info-value">@Model.FirstName</div>
            </div>

            <div class="info-item">
                <span class="info-label"><i class="icon name-icon">👥</i> Фамилия</span>
                <div class="info-value">@Model.LastName</div>
            </div>

            <div class="info-item">
                <span class="info-label"><i class="icon email-icon">✉️</i> Email</span>
                <div class="info-value">@Model.Email</div>
            </div>

            <div class="info-item">
                <span class="info-label"><i class="icon birthday-icon">🎂</i> Дата рождения</span>
                <div class="info-value">@Model.BirthDate.ToString("dd.MM.yyyy")</div>
            </div>
        </div>
    </div>

    <div class="buttons-container">
        <button type="button"
                onclick="window.location.href='@Url.Action("FriendsView", "Friends")'"
                class="profile-btn btn-friends">
            <i class="icon">👥</i> Мои друзья
        </button>

        <a href="@Url.Action("MyMessages", "Messege")"
           class="profile-btn btn-messages">
            <i class="icon">💬</i> Мои сообщения
        </a>

        <button type="button"
                onclick="window.location.href='@Url.Action("EditProfile", "Home")'"
                class="profile-btn btn-edit">
            <i class="icon">✏️</i> Редактировать профиль
        </button>
    </div>
</div>

<script>
    // Добавляем небольшой эффект при наведении на элементы профиля
    document.querySelectorAll('.info-item').forEach(item => {
        item.addEventListener('mouseenter', function() {
            this.style.transform = 'translateY(-2px)';
        });
        item.addEventListener('mouseleave', function() {
            this.style.transform = 'translateY(0)';
        });
    });
</script>